---
interface Props {
  image: string;
  imageAlt: string;
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}
const { image, imageAlt, title, subtitle, ctaText, ctaHref } = Astro.props;
---

<section class="hero" aria-label="ヒーローセクション">
  <!-- 背景 -->
  <div class="hero-bg img-placeholder" aria-hidden="true">
    <img
      src={image}
      alt=""
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="hero-img"
      data-fallback
    />
    <div class="hero-overlay" />
  </div>

  <!-- テキスト -->
  <div class="site-container hero-content">
    <div class="hero-text">
      {subtitle && <p class="hero-sub">{subtitle}</p>}
      <h1 class="hero-title">{title}</h1>
      {ctaText && ctaHref && (
        <a href={ctaHref} class="hero-cta">
          {ctaText}
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      )}
    </div>
  </div>

  <!-- スクロールインジケーター -->
  <div class="scroll-indicator" aria-hidden="true">
    <span class="scroll-label">Scroll</span>
    <div class="scroll-track">
      <div class="scroll-thumb" />
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  width: 100%;
  height: 90svh;
  min-height: 520px;
  max-height: 1000px;
  overflow: hidden;
}

/* 背景 */
.hero-bg {
  position: absolute;
  inset: 0;
  background-color: #2a2826;
}
.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(28, 28, 26, 0.1) 0%,
    rgba(28, 28, 26, 0.6) 100%
  );
}

/* コンテンツ */
.hero-content {
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding-bottom: clamp(3rem, 7vw, 6rem);
}
.hero-text { max-width: 48rem; }

.hero-sub {
  font-size: 0.62rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.55);
  margin-bottom: 1rem;
}
.hero-title {
  color: #ffffff;
  font-weight: 300;
  line-height: 1.15;
  letter-spacing: -0.02em;
  font-size: clamp(2.4rem, 7vw, 5.5rem);
}

/* スクロールインジケーター */
.scroll-indicator {
  position: absolute;
  bottom: 2rem;
  right: clamp(1.5rem, 3vw, 3rem);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
}
.scroll-label {
  font-size: 0.55rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.4);
  writing-mode: vertical-rl;
}
.scroll-track {
  width: 1px;
  height: 48px;
  background: rgba(255, 255, 255, 0.2);
  overflow: hidden;
  position: relative;
}
.scroll-thumb {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 50%;
  background: rgba(255, 255, 255, 0.65);
  animation: scrollDown 2s ease-in-out infinite;
}
</style>
