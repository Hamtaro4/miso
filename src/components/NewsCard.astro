---
interface Props {
  slug: string;
  title: string;
  pubDate: Date;
  category: string;
  description: string;
  variant?: 'default' | 'compact';
}
const { slug, title, pubDate, category, description, variant = 'default' } = Astro.props;
const dateStr = new Intl.DateTimeFormat('ja-JP', { year:'numeric', month:'long', day:'numeric' }).format(pubDate);
---

{variant === 'compact' ? (
  <article class="news-compact">
    <a href={`/news/${slug}`} class="news-compact-link">
      <time datetime={pubDate.toISOString()} class="nc-date label">{dateStr}</time>
      <span class="nc-cat label">{category}</span>
      <h3 class="nc-title card-title">{title}</h3>
    </a>
  </article>
) : (
  <article class="news-default">
    <a href={`/news/${slug}`} class="news-link">
      <div class="nd-meta">
        <time datetime={pubDate.toISOString()} class="label">{dateStr}</time>
        <span class="label">{category}</span>
      </div>
      <h3 class="nd-title card-title">{title}</h3>
      <p class="nd-desc">{description}</p>
    </a>
  </article>
)}

<style>
/* compact */
.news-compact { border-bottom: 1px solid #E5E4E0; padding: 1.1rem 0; }
.news-compact-link {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 0.4rem 1rem;
}
.nc-date { min-width: 7rem; color: #6B6B68; }
.nc-cat  { color: #6B6B68; }
.nc-title {
  font-size: 0.875rem;
  font-weight: 400;
  color: #1C1C1A;
  transition: color 0.2s;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}
.news-compact-link:hover .nc-title { color: #C9A96E; }

/* default */
.news-default { border-bottom: 1px solid #E5E4E0; padding: 1.75rem 0; }
.news-link { display: block; }
.nd-meta { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.6rem; color: #6B6B68; }
.nd-title {
  font-size: 1rem;
  font-weight: 500;
  color: #1C1C1A;
  margin-bottom: 0.4rem;
  transition: color 0.2s;
}
.news-link:hover .nd-title { color: #C9A96E; }
.nd-desc {
  font-size: 0.875rem;
  color: #6B6B68;
  line-height: 1.7;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
</style>
