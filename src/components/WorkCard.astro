---
interface Props {
  slug: string;
  title: string;
  titleEn?: string;
  category: string;
  mainImage: string;
  index?: number;
}
const { slug, title, titleEn, category, mainImage, index = 0 } = Astro.props;
---

<article class="wc-wrap" data-index={index}>
  <a href={`${import.meta.env.BASE_URL}/works/${slug}`} class="wc-link" aria-label={`${title} — 詳細を見る`}>
    <!-- 画像エリア -->
    <div class="wc-img img-placeholder">
      <img
        src={`${import.meta.env.BASE_URL}${mainImage}`}
        alt={titleEn ? `${title} / ${titleEn}` : title}
        width="1280"
        height="720"
        loading="lazy"
        decoding="async"
        data-fallback
      />
    </div>
    <!-- テキスト：常に表示（モバイルでもホバーなしで読める） -->
    <div class="wc-info">
      <span class="wc-cat">{category}</span>
      <h3 class="wc-title">{title}</h3>
    </div>
  </a>
</article>

<script>
  function initScrollReveal() {
    const cards = document.querySelectorAll<HTMLElement>('.wc-wrap');
    if (!cards.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05, rootMargin: '0px 0px -40px 0px' }
    );

    cards.forEach((card) => {
      const rect = card.getBoundingClientRect();
      if (rect.top < window.innerHeight) {
        card.classList.add('is-visible');
      } else {
        io.observe(card);
      }
    });
  }

  initScrollReveal();
  document.addEventListener('astro:page-load', initScrollReveal);
</script>

<style>
.wc-wrap {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.wc-wrap[data-index="1"],
.wc-wrap[data-index="3"],
.wc-wrap[data-index="5"],
.wc-wrap[data-index="7"] {
  transition-delay: 0.1s;
}
.wc-wrap.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.wc-link { display: block; }

/* 画像: 16:9（Minecraftスクリーンショットに最適） */
.wc-img {
  aspect-ratio: 16 / 9;
  overflow: hidden;
}
.wc-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.wc-link:hover .wc-img img {
  transform: scale(1.04);
}

/* テキスト: 常に表示 */
.wc-info {
  padding: 0.7rem 0 0;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}
.wc-cat {
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #9D9C99;
}
.wc-title {
  font-size: 0.9rem;
  font-weight: 400;
  color: #1C1C1A;
  line-height: 1.45;
  transition: color 0.2s;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.wc-link:hover .wc-title {
  color: #6B6B68;
}
</style>
