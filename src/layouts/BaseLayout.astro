---
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/config';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  jsonLd?: object | object[];
  heroPage?: boolean;      // trueならヒーロー画像がある → ヘッダー透明スタート
  heroImage?: string;      // ヒーロー画像パス → preload に使用
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  ogType = 'website',
  jsonLd,
  heroPage = false,
  heroImage,
} = Astro.props;

const fullTitle = title === SITE.name ? title : `${title} | ${SITE.name}`;
const canonical  = new URL(Astro.url.pathname, SITE.url).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE.url}${ogImage}`;

// JSON-LD: 組織スキーマは全ページ共通
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  alternateName: SITE.nameEn,
  url: SITE.url,
  sameAs: [SITE.twitterUrl],
};
const allLd = [orgLd, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content={SITE.themeColor} />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="建築,都市デザイン,まちづくり,味噌汁市,ポートフォリオ,コミュニティ" />
    <meta name="author" content={SITE.name} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- OGP -->
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:type"        content={ogType} />
    <meta property="og:locale"      content="ja_JP" />
    <meta property="og:site_name"   content={SITE.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:site"        content={SITE.twitter} />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />

    <!-- Fonts: preconnect → fallback stylesheet -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500&family=Inter:wght@300;400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500&family=Inter:wght@300;400;500&display=swap"
      />
    </noscript>

    <!-- Hero image preload (LCP最適化) -->
    {heroPage && heroImage && (
      <link rel="preload" as="image" href={heroImage} fetchpriority="high" />
    )}

    <!-- JSON-LD (type="application/ld+json" は script-src の適用外) -->
    {allLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <!-- View Transitions -->
    <ClientRouter />
  </head>
  <body>
    <!-- Skip link: CSS only (インラインJS不使用) -->
    <a href="#main-content" class="skip-link">本文へスキップ</a>

    <Header heroPage={heroPage} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <!-- 画像エラーハンドラ: グローバルスクリプト (インラインonerror属性不使用 → CSP強化) -->
    <script>
      function handleImgErrors() {
        document.querySelectorAll('img[data-fallback]').forEach((img) => {
          (img as HTMLImageElement).addEventListener('error', () => {
            img.classList.add('img-error');
          });
        });
      }
      // 初回実行
      handleImgErrors();
      // View Transitions後も再実行
      document.addEventListener('astro:page-load', handleImgErrors);
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .skip-link:focus {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 9999;
    background: #C9A96E;
    color: #1C1C1A;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    width: auto;
    height: auto;
    font-size: 0.875rem;
    font-weight: 500;
  }
</style>
