---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import WorkCard from '@/components/WorkCard.astro';
import NewsCard from '@/components/NewsCard.astro';
import { SITE, CONTACT_FORM_URL, YOUTUBE_VIDEOS } from '@/config';
const featuredVideo = YOUTUBE_VIDEOS.find(v => v.featured);
const subVideos     = YOUTUBE_VIDEOS.filter(v => !v.featured);

// トップページのテキストを content/pages/index.md から読み込む
const pageContent = await getEntry('pages', 'index');
const pd = pageContent.data;

const allWorks = await getCollection('works', ({ data }) => !data.draft);
const featured = allWorks
  .filter(w => w.data.featured)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 4);

const allNews = await getCollection('news', ({ data }) => !data.draft);
const latestNews = allNews
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const HERO_IMAGE = `${import.meta.env.BASE_URL}/images/hero.jpg`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
};
---

<BaseLayout
  title={SITE.name}
  heroPage={true}
  heroImage={HERO_IMAGE}
  jsonLd={jsonLd}
>
  <!-- ヒーロー -->
  <HeroSection
    image={HERO_IMAGE}
    imageAlt="味噌汁市の建築作品"
    title={pd.heroTitle ?? "建築で、まちを作る。"}
    subtitle="MISOSIRU CITY"
    ctaText="WORKS を見る"
    ctaHref={`${import.meta.env.BASE_URL}/works`}
  />

  <!-- Featured Works -->
  <section class="works-section" aria-labelledby="works-heading">
    <div class="site-container">
      <div class="section-header">
        <h2 id="works-heading" class="section-title">WORKS</h2>
        <a href={`${import.meta.env.BASE_URL}/works`} class="section-more-link" aria-label="すべての作品を見る">
          すべての作品
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="works-grid">
        {featured.map((w, i) => (
          <WorkCard
            slug={w.slug}
            title={w.data.title}
            titleEn={w.data.titleEn}
            category={w.data.category}
            mainImage={w.data.mainImage}
            index={i}
          />
        ))}
      </div>

      <div class="section-more-mobile">
        <a href={`${import.meta.env.BASE_URL}/works`} class="label footer-link" aria-label="すべての作品を見る">
          すべての作品を見る →
        </a>
      </div>
    </div>
  </section>

  <div class="site-container"><hr class="divider" /></div>

  <!-- Latest News -->
  <section class="news-section" aria-labelledby="news-heading">
    <div class="site-container">
      <div class="section-header">
        <h2 id="news-heading" class="section-title">NEWS</h2>
        <a href={`${import.meta.env.BASE_URL}/news`} class="section-more-link" aria-label="すべてのお知らせを見る">
          すべてのお知らせ
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="news-list">
        {latestNews.map(item => (
          <NewsCard
            slug={item.slug}
            title={item.data.title}
            pubDate={item.data.pubDate}
            category={item.data.category}
            description={item.data.description}
            variant="compact"
          />
        ))}
      </div>

      <div class="section-more-mobile">
        <a href={`${import.meta.env.BASE_URL}/news`} class="label footer-link" aria-label="すべてのお知らせを見る">
          すべてのお知らせを見る →
        </a>
      </div>
    </div>
  </section>

  <div class="site-container"><hr class="divider" /></div>

  <!-- YouTube -->
  <section class="yt-section" aria-labelledby="yt-heading">
    <div class="site-container">
      <div class="section-header">
        <h2 id="yt-heading" class="section-title">YOUTUBE</h2>
        <a
          href="https://www.youtube.com/@MisosiruCity"
          target="_blank"
          rel="noopener noreferrer"
          class="section-more-link label"
          aria-label="YouTubeチャンネルを見る"
        >
          チャンネルを見る
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- 注目動画（大きく表示） -->
      {featuredVideo && (
        <a
          href={`https://www.youtube.com/watch?v=${featuredVideo.id}`}
          target="_blank"
          rel="noopener noreferrer"
          class="yt-featured"
          aria-label={`${featuredVideo.title} — YouTubeで見る`}
        >
          <div class="yt-featured-thumb">
            <img
              src={`https://i.ytimg.com/vi/${featuredVideo.id}/maxresdefault.jpg`}
              alt={featuredVideo.title}
              width="1280"
              height="720"
              loading="lazy"
              decoding="async"
            />
            <div class="yt-play-overlay" aria-hidden="true">
              <div class="yt-play-btn">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
          </div>
          <p class="yt-featured-title">{featuredVideo.title}</p>
        </a>
      )}

      <!-- サブ動画グリッド -->
      {subVideos.length > 0 && (
        <div class="yt-grid">
          {subVideos.map(v => (
            <a
              href={`https://www.youtube.com/watch?v=${v.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="yt-card"
              aria-label={`${v.title} — YouTubeで見る`}
            >
              <div class="yt-card-thumb">
                <img
                  src={`https://i.ytimg.com/vi/${v.id}/mqdefault.jpg`}
                  alt={v.title}
                  width="320"
                  height="180"
                  loading="lazy"
                  decoding="async"
                />
                <div class="yt-card-play" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              <p class="yt-card-title">{v.title}</p>
            </a>
          ))}
        </div>
      )}

      <div class="section-more-mobile">
        <a href="https://www.youtube.com/@MisosiruCity" target="_blank" rel="noopener noreferrer" class="label footer-link">
          YouTubeチャンネルを見る →
        </a>
      </div>
    </div>
  </section>

  <!-- About CTA -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="site-container cta-inner">
      <p class="label cta-label">About</p>
      <h2 id="cta-heading" class="cta-title">
        {(pd.ctaTitle ?? "まちを、\n一緒につくりませんか。").split('\n').map((line, i) => (
          i > 0 ? <><br />{line}</> : <>{line}</>
        ))}
      </h2>
      <p class="cta-body">
        {pd.ctaBody ?? "味噌汁市は、建築・都市デザインを通じてまちの可能性を探るクリエイティブ集団です。多様なバックグラウンドを持つメンバーとともに活動しています。"}
      </p>
      <div class="cta-actions">
        <a href={`${import.meta.env.BASE_URL}/recruit`} class="btn-primary">
          制作員募集
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href={CONTACT_FORM_URL} target="_blank" rel="noopener noreferrer" class="btn-ghost-light">
          お問い合わせ
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* Works section */
.works-section { padding: 6rem 0 4rem; }
.news-section  { padding: 5rem 0 6rem; }

.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 2.5rem;
}
.section-title {
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 300;
  letter-spacing: -0.01em;
}
.section-more-link {
  display: none;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #6B6B68;
  transition: color 0.2s;
}
.section-more-link:hover { color: #1C1C1A; }
@media (min-width: 768px) {
  .section-more-link { display: flex; }
}
.section-more-mobile {
  margin-top: 2.5rem;
  text-align: center;
}
@media (min-width: 768px) {
  .section-more-mobile { display: none; }
}

.works-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem 2.5rem;
}
@media (min-width: 768px) {
  .works-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem 2.5rem; }
}

.news-list { max-width: 48rem; }
.divider { border: none; border-top: 1px solid #E5E4E0; }

/* YouTube section */
.yt-section { padding: 5rem 0 6rem; }

/* 注目動画 */
.yt-featured {
  display: block;
  margin-bottom: 2rem;
}
.yt-featured-thumb {
  position: relative;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: #1C1C1A;
  border-radius: 2px;
}
.yt-featured-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease, filter 0.4s ease;
}
.yt-featured:hover .yt-featured-thumb img {
  transform: scale(1.03);
  filter: brightness(0.75);
}
.yt-play-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.yt-play-btn {
  width: 5rem;
  height: 5rem;
  border-radius: 50%;
  background: rgba(0,0,0,0.6);
  border: 2px solid rgba(255,255,255,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  transition: background 0.25s, transform 0.25s;
}
.yt-featured:hover .yt-play-btn {
  background: #FF0000;
  border-color: #FF0000;
  transform: scale(1.1);
}
.yt-featured-title {
  margin-top: 0.9rem;
  font-size: 1rem;
  font-weight: 400;
  color: #1C1C1A;
  line-height: 1.5;
  transition: color 0.2s;
}
.yt-featured:hover .yt-featured-title { color: #6B6B68; }

/* サブ動画グリッド */
.yt-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}
@media (min-width: 768px) {
  .yt-grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
}
.yt-card { display: block; }
.yt-card-thumb {
  position: relative;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: #1C1C1A;
  border-radius: 2px;
  margin-bottom: 0.6rem;
}
.yt-card-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease, filter 0.3s ease;
}
.yt-card:hover .yt-card-thumb img {
  transform: scale(1.04);
  filter: brightness(0.7);
}
.yt-card-play {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  opacity: 0;
  transition: opacity 0.25s;
}
.yt-card:hover .yt-card-play { opacity: 1; }
.yt-card-title {
  font-size: 0.8rem;
  color: #3A3A38;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: color 0.2s;
}
.yt-card:hover .yt-card-title { color: #6B6B68; }

/* CTA section */
.cta-section {
  background-color: #1C1C1A;
  color: #F8F7F4;
  padding: 6rem 0;
}
.cta-inner { text-align: center; }
.cta-label { color: rgba(248,247,244,0.35); margin-bottom: 1.5rem; }
.cta-title {
  font-size: clamp(1.75rem, 4vw, 3rem);
  font-weight: 300;
  line-height: 1.35;
  margin-bottom: 1.5rem;
}
.cta-body {
  font-size: 0.875rem;
  color: rgba(248,247,244,0.6);
  line-height: 1.9;
  max-width: 36rem;
  margin: 0 auto 2.5rem;
}
.cta-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}
@media (min-width: 480px) {
  .cta-actions { flex-direction: row; justify-content: center; }
}
</style>
