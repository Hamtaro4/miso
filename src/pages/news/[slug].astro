---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config';

export async function getStaticPaths() {
  const news = await getCollection('news', ({ data }) => !data.draft);
  return news.map(item => ({ params: { slug: item.slug }, props: { item } }));
}

interface Props { item: CollectionEntry<'news'>; }

const { item } = Astro.props;
const { data, slug } = item;
const { Content } = await item.render();
const dateStr = new Intl.DateTimeFormat('ja-JP', { year:'numeric', month:'long', day:'numeric' }).format(data.pubDate);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  datePublished: data.pubDate.toISOString(),
  author:    { '@type': 'Organization', name: SITE.name },
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  url: `${SITE.url}/news/${slug}`,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'NEWS',   item: `${SITE.url}/news` },
      { '@type': 'ListItem', position: 3, name: data.title, item: `${SITE.url}/news/${slug}` },
    ],
  },
};
---

<BaseLayout
  title={data.title}
  description={data.description}
  ogImage={data.image}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="site-container news-article">

    <!-- パンくず -->
    <nav aria-label="パンくずリスト" class="bc-nav">
      <ol class="bc-list">
        <li><a href={import.meta.env.BASE_URL} class="bc-link">ホーム</a></li>
        <li aria-hidden="true" class="bc-sep">›</li>
        <li><a href={`${import.meta.env.BASE_URL}/news`} class="bc-link">NEWS</a></li>
        <li aria-hidden="true" class="bc-sep">›</li>
        <li aria-current="page" class="bc-curr">{data.title}</li>
      </ol>
    </nav>

    <div class="article-meta">
      <time datetime={data.pubDate.toISOString()} class="label">{dateStr}</time>
      <span class="label">{data.category}</span>
    </div>

    <h1 class="article-title">{data.title}</h1>

    {data.image && (
      <div class="article-img img-placeholder">
        <img
          src={`${import.meta.env.BASE_URL}${data.image}`}
          alt={data.title}
          width="1200"
          height="675"
          loading="eager"
          data-fallback
        />
      </div>
    )}

    <div class="prose">
      <Content />
    </div>

    <div class="back-link-wrap">
      <a href={`${import.meta.env.BASE_URL}/news`} class="back-link label">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        NEWS 一覧に戻る
      </a>
    </div>
  </article>
</BaseLayout>

<style>
.news-article { padding: 8rem 0; max-width: 48rem; }

/* パンくず */
.bc-nav { margin-bottom: 2rem; }
.bc-list { display:flex; flex-wrap:wrap; gap:0.25rem; list-style:none; padding:0; margin:0; }
.bc-link { font-size:0.7rem; color:#6B6B68; transition:color 0.2s; }
.bc-link:hover { color:#1C1C1A; }
.bc-sep { font-size:0.7rem; color:#D0CBC4; }
.bc-curr { font-size:0.7rem; color:#1C1C1A; }

.article-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
  color: #6B6B68;
}
.article-title {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 300;
  line-height: 1.4;
  letter-spacing: -0.01em;
  margin-bottom: 3rem;
}
.article-img {
  aspect-ratio: 16 / 9;
  overflow: hidden;
  margin-bottom: 3rem;
}
.article-img img { width:100%; height:100%; object-fit:cover; display:block; }

.back-link-wrap {
  margin-top: 3.5rem;
  padding-top: 2rem;
  border-top: 1px solid #E5E4E0;
}
.back-link {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  color: #6B6B68;
  transition: color 0.2s;
}
.back-link:hover { color: #1C1C1A; }
</style>
